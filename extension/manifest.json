{
  "manifest_version": 3,
  "name": "LeetTrack",
  "description": "Detect the active LeetCode problem so LeetTrack can connect browser context to your tracker.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "src/popup.html",
    "default_title": "LeetTrack"
  },
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://*.leetcode.com/problems/*"
      ],
      "js": ["src/problemPage.js", "src/contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
