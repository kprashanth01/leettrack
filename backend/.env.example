# local keeps development flexible. Set APP_ENV=production on Render/Railway.
APP_ENV=local

# Preferred for deployed backend: Supabase pooler connection string.
# Use this on Render/Railway when direct IPv6 connections are unreliable.
# If your password contains special characters, it must be URL-encoded.
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Alternative: paste Supabase database parts separately.
# This avoids URL-encoding problems when passwords contain special characters.
SUPABASE_DB_HOST=db.[PROJECT_REF].supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=[PASSWORD]

# Comma-separated frontend origins allowed to call the API.
# Add your Vercel production and preview URLs before deploying.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://[FRONTEND_PROJECT].vercel.app

# Supabase Auth verification for protected FastAPI endpoints.
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_PUBLISHABLE_KEY=[PUBLISHABLE_KEY]

# Resend email delivery for manual weekly summary emails.
RESEND_API_KEY=re_[RESEND_API_KEY]
EMAIL_FROM=LeetTrack <onboarding@resend.dev>

# Shared secret required by cron runners that call the weekly email dispatcher.
SCHEDULER_SECRET=replace-with-a-long-random-secret
