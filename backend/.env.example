# Preferred: paste Supabase database parts separately.
# This avoids URL-encoding problems when passwords contain special characters.
SUPABASE_DB_HOST=db.[PROJECT_REF].supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=[PASSWORD]

# Alternative: use a full Supabase Postgres connection string.
# If your password contains special characters, it must be URL-encoded.
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
